@page "/unauthorized"
@rendermode InteractiveServer

<PageTitle>Non autorisé</PageTitle>

<div class="alert alert-warning" role="alert">
    <h4 class="alert-heading">Accès refusé</h4>
    <p>Vous n'êtes pas autorisé à accéder à cette ressource.</p>
    <hr />
    <p class="mb-0">
        <a href="/login" class="btn btn-primary">Retour à la connexion</a>
    </p>
</div>
