@inherits LayoutComponentBase

<div class="page @(!_isMenuCollapsed ? "menu-open" : string.Empty)">
    <header class="app-header">
        <div class="top-row px-4 app-header-row">
            <button class="menu-toggle" type="button" @onclick="@ToggleMenu" aria-controls="sidebar-nav" aria-expanded="@(!_isMenuCollapsed ? "true" : "false")">
                <span class="menu-toggle-icon" aria-hidden="true"></span>
                <span class="sr-only">Menu</span>
            </button>
            <span class="app-title">GEntretien</span>
            <div class="header-actions">
                <span class="version-badge">@($"v{_version}")</span>
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
        </div>
    </header>

    <div class="layout-body">
        <nav id="sidebar-nav" class="sidebar @( _isMenuCollapsed ? "collapsed" : string.Empty)" aria-label="Main navigation">
            <NavMenu IsCollapsed="@_isMenuCollapsed" OnCollapseChanged="SetCollapsed" />
        </nav>

        <main>
            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

