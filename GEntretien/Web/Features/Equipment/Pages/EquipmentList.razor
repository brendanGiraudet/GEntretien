@page "/equipment"
@using GEntretien.Domain.Entities
@using GEntretien.Domain.Interfaces

<h3>Equipements</h3>

<button class="btn btn-primary" @onclick="CreateNew">Créer un équipement</button>

<table class="table mt-3">
    <thead>
        <tr>
            <th>Id</th>
            <th>Image</th>
            <th>Nom</th>
            <th>Serial</th>
            <th>Location</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (_equipments is null)
        {
            <tr><td colspan="6">Chargement...</td></tr>
        }
        else if (!_equipments.Any())
        {
            <tr><td colspan="6">Aucun équipement</td></tr>
        }
        else
        {
            @foreach (var e in _equipments)
            {
                <tr>
                    <td>@e.Id</td>
                    <td>
                        @if (e.ImageData?.Length > 0)
                        {
                            <img src="data:@(e.ImageContentType ?? "image/jpeg");base64,@Convert.ToBase64String(e.ImageData)" 
                                 alt="@e.Name" 
                                 class="img-thumbnail" 
                                 style="max-width: 50px; max-height: 50px;" />
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>@e.Name</td>
                    <td>@e.SerialNumber</td>
                    <td>@e.Location</td>
                    <td>
                        <a class="btn btn-sm btn-secondary" href="/equipment/edit/@e.Id">Éditer</a>
                        <a class="btn btn-sm btn-outline-secondary ms-1" href="/equipment/@e.Id/interventions">Historique</a>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(e.Id)">Supprimer</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
