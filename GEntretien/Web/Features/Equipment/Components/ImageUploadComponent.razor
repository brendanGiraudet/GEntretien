@using Microsoft.AspNetCore.Components.Forms
@using GEntretien.Application.Services

<div class="mb-3">
    <label class="form-label">Image</label>
    
    @if (HasImage)
    {
        <div class="mb-2">
            <div class="text-center">
                <img src="data:@ImageContentType;base64,@Convert.ToBase64String(ImageData!)" 
                     alt="Image actuelle" 
                     class="img-thumbnail" 
                     style="max-width: 200px; max-height: 200px;" />
            </div>
            <button type="button" class="btn btn-sm btn-danger" @onclick="RemoveImage">Supprimer l'image</button>
        </div>
    }
    
    <InputFile class="form-control" OnChange="HandleFileSelected" accept="image/*" />
    
    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <div class="alert @StatusClass mt-2" role="alert">
            @StatusMessage
        </div>
    }
</div>
