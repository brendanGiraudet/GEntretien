@using GEntretien.Application.Services

<div class="qrcode-container">
    @if (string.IsNullOrEmpty(QRCodeSvg))
    {
        <div class="text-center py-3">
            <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Génération...</span>
            </div>
        </div>
    }
    else
    {
        <div class="text-center">
            <div class="qrcode-display bg-white p-3 rounded border d-inline-block" style="display: inline-block;">
                @((MarkupString)QRCodeSvg)
            </div>
            <div class="mt-2">
                <button class="btn btn-sm btn-outline-primary" @onclick="PrintQRCode" title="Imprimer le QR code">
                    🖨️ Imprimer QR Code
                </button>
            </div>
        </div>
    }
</div>
