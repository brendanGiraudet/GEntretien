# Configuration d'Environnement pour GEntretien
# Copier ce fichier dans `.env` et remplacer par vos vraies valeurs
# Ne JAMAIS commiter votre fichier .env réel dans git!

# Credentials Google OAuth 2.0
# Obtenir depuis: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Database
DATABASE_PATH=/app/data/app.db

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
